generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CustomerStage {
  NEW
  FIRST_CONTACT
  FOLLOWING_UP
  INTERESTED
  NEGOTIATING
  WAITING_PAYMENT
  PAID
  AFTER_SALES
  LOST
}

enum MessageRole {
  CUSTOMER
  OPERATOR
}

enum MessageType {
  TEXT
  IMAGE
  STICKER
}

enum MessageSource {
  LINE
  MANUAL
  AI_SUGGESTION
}



enum MessageSendStatus {
  PENDING
  SENT
  FAILED
}

enum OutboundTaskStatus {
  PENDING
  CLAIMED
  SENT
  FAILED
  CANCELED
}

enum ScheduledMessageStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELED
}

enum SuggestionVariant {
  STABLE
  ADVANCING
}

enum AutomationJobKind {
  INBOUND_WORKFLOW
  INBOUND_TRANSLATION
}

enum UiRefreshOutboxStatus {
  PENDING
  DELIVERED
  FAILED
}

enum AutomationJobStatus {
  PENDING
  RUNNING
  DONE
  SKIPPED
  FAILED
}

enum GenerationTaskStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum GenerationTaskTriggerSource {
  MANUAL_GENERATE
  AUTO_FIRST_INBOUND
}
enum FollowupBucket {
  UNCONVERTED
  VIP
}

enum FollowupTier {
  A
  B
  C
}

enum FollowupState {
  ACTIVE
  OBSERVING
  WAITING_WINDOW
  POST_PURCHASE_CARE
  DONE
  PAUSED
}

enum FollowupTimingBucket {
  IMMEDIATE
  TODAY
  IN_1_DAY
  IN_3_DAYS
  IN_7_DAYS
  NO_SET
}

enum LineRelationshipStatus {
  ACTIVE
  UNFOLLOWED
}

model Customer {
  id                     String        @id @default(cuid())
  lineUserId             String?       @unique
  bridgeThreadId         String?       @unique
  remarkName             String?
  originalName           String
  avatarUrl              String?
  stage                  CustomerStage @default(NEW)
  isVip                  Boolean       @default(false)
  pinnedAt               DateTime?
  unreadCount            Int           @default(0)
  lineRelationshipStatus LineRelationshipStatus @default(ACTIVE)
  lineRelationshipUpdatedAt DateTime?
  lineRefollowedAt       DateTime?

  followupBucket         FollowupBucket?
  followupTier           FollowupTier?
  followupState          FollowupState @default(ACTIVE)
  nextFollowupBucket     FollowupTimingBucket?
  nextFollowupAt         DateTime?
  followupReason         String?
  riskTags               String[]       @default([])
  lastFollowupHandledAt  DateTime?
  followupUpdatedAt      DateTime?

  aiCustomerInfo         String?
  aiCurrentStrategy      String?
  aiLastAnalyzedAt       DateTime?

  lastMessageAt          DateTime?
  lastInboundMessageAt   DateTime?
  lastOutboundMessageAt  DateTime?

  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  tags                   CustomerTag[]
  messages               Message[]
  outboundTasks          OutboundTask[]
  scheduledMessages      ScheduledMessage[]
  replyDraftSets         ReplyDraftSet[]
  automationJobs         AutomationJob[]
  generationTasks        GenerationTask[]
  uiRefreshOutboxEntries UiRefreshOutbox[]

  @@index([stage])
  @@index([isVip])
  @@index([lastMessageAt(sort: Desc)])
  @@index([originalName])
  @@index([remarkName])
  @@index([bridgeThreadId])
  @@index([pinnedAt(sort: Desc)])
  @@index([lineRelationshipStatus])
  @@index([followupBucket, followupTier])
  @@index([nextFollowupBucket])
  @@index([nextFollowupAt(sort: Asc)])
}

model Tag {
  id          String        @id @default(cuid())
  name        String        @unique
  color       String?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  customers   CustomerTag[]

  @@index([sortOrder])
}

model CustomerTag {
  customerId  String
  tagId       String
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@index([tagId])
}

model Message {
  id              String        @id @default(cuid())
  customerId      String
  role            MessageRole
  type            MessageType   @default(TEXT)
  source          MessageSource
  lineMessageId   String?       @unique
  fingerprint     String?       @unique

  japaneseText    String
  chineseText     String?
  imageUrl        String?
  stickerPackageId String?
  stickerId       String?

  deliveryStatus  MessageSendStatus?
  sendError       String?
  lastAttemptAt   DateTime?
  failedAt        DateTime?
  retryCount      Int           @default(0)

  sentAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  outboundTask    OutboundTask?
  generationTasks GenerationTask[]

  @@index([customerId, sentAt(sort: Asc)])
  @@index([customerId, role, sentAt(sort: Desc)])
}


model OutboundTask {
  id             String             @id @default(cuid())
  customerId     String
  messageId      String             @unique
  bridgeThreadId String
  status         OutboundTaskStatus @default(PENDING)
  claimedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  lastError      String?
  attemptCount   Int                @default(0)
  nextRetryAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  customer       Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  message        Message            @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([status, createdAt(sort: Asc)])
  @@index([bridgeThreadId, status])
  @@index([nextRetryAt])
}

model ScheduledMessage {
  id                String                 @id @default(cuid())
  customerId        String
  type              MessageType            @default(TEXT)
  source            MessageSource          @default(MANUAL)
  japaneseText      String
  chineseText       String?
  imageUrl          String?
  scheduledFor      DateTime
  status            ScheduledMessageStatus @default(PENDING)
  replyDraftSetId   String?
  suggestionVariant SuggestionVariant?
  deliveredMessageId String?               @unique
  lastAttemptAt     DateTime?
  processedAt       DateTime?
  failedAt          DateTime?
  canceledAt        DateTime?
  sendError         String?
  retryCount        Int                    @default(0)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  customer          Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor(sort: Asc)])
  @@index([customerId, scheduledFor(sort: Desc)])
  @@index([customerId, status, scheduledFor(sort: Asc)])
}

model ReplyDraftSet {
  id                      String            @id @default(cuid())
  customerId              String
  targetCustomerMessageId String?

  extraRequirement        String?

  stableJapanese          String
  stableChinese           String

  advancingJapanese       String
  advancingChinese        String

  modelName               String
  translationPromptVersion String?
  analysisPromptVersion   String?
  generationPromptVersion String?
  reviewPromptVersion     String?
  sceneType               String?
  routeType               String?
  replyGoal               String?
  pushLevel               String?
  generationBriefJson     String?
  reviewFlagsJson         String?
  programChecksJson       String?
  aiReviewJson            String?
  finalGateJson           String?
  differenceNote          String?
  selfCheckJson           String?
  recommendedVariant      SuggestionVariant?
  isStale                 Boolean           @default(false)
  staleReason             String?
  staleAt                 DateTime?
  selectedVariant         SuggestionVariant?
  selectedAt              DateTime?

  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  customer                Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  generationTasks         GenerationTask[]

  @@index([customerId, createdAt(sort: Desc)])
  @@index([customerId, targetCustomerMessageId])
  @@index([customerId, isStale, createdAt(sort: Desc)])
}

model GenerationTask {
  id                      String                      @id @default(cuid())
  customerId              String
  targetMessageId         String?
  dedupeKey               String?
  rewriteInput            String?
  autoMode                Boolean                     @default(false)
  triggerSource           GenerationTaskTriggerSource
  status                  GenerationTaskStatus        @default(PENDING)
  stage                   String                      @default("queued")
  errorCode               String?
  errorMessage            String?
  errorDetailsJson        String?
  resultDraftSetId        String?
  attemptCount            Int                         @default(0)
  maxAttempts             Int                         @default(2)
  nextRetryAt             DateTime?
  leaseExpiresAt          DateTime?
  startedAt               DateTime?
  finishedAt              DateTime?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  customer                Customer                    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  targetMessage           Message?                    @relation(fields: [targetMessageId], references: [id], onDelete: SetNull)
  resultDraftSet          ReplyDraftSet?              @relation(fields: [resultDraftSetId], references: [id], onDelete: SetNull)

  @@index([status, nextRetryAt, createdAt(sort: Asc)])
  @@index([customerId, createdAt(sort: Desc)])
  @@index([targetMessageId])
  @@index([resultDraftSetId])
  @@index([dedupeKey])
}

model AutomationJob {
  id              String              @id @default(cuid())
  customerId      String
  targetMessageId String
  kind            AutomationJobKind
  status          AutomationJobStatus @default(PENDING)
  scheduledFor    DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  attemptCount    Int                 @default(0)
  lastError       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  customer        Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, targetMessageId, kind])
  @@index([status, scheduledFor])
  @@index([customerId, updatedAt(sort: Desc)])
}



model UiRefreshOutbox {
  id           String              @id @default(cuid())
  customerId   String?
  reason       String
  scopes       String[]            @default([])
  payload      Json?
  status       UiRefreshOutboxStatus @default(PENDING)
  attemptCount Int                 @default(0)
  lastError    String?
  nextRetryAt  DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  customer     Customer?           @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt, createdAt(sort: Asc)])
  @@index([customerId, createdAt(sort: Desc)])
}

model LineWebhookEventReceipt {
  webhookEventId String   @id
  lineUserId     String?
  eventType      String
  isRedelivery   Boolean  @default(false)
  occurredAt     DateTime?
  createdAt      DateTime @default(now())

  @@index([lineUserId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
}

model OperatorPresence {
  id                 String   @id
  selectedCustomerId String?
  lastSeenAt         DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PresetSnippet {
  id        String   @id @default(cuid())
  title     String
  content   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([updatedAt(sort: Desc)])
}
